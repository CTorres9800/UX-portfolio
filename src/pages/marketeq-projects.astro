      <div class="cs-image-block cs-image-block--wide"><img src="/images/cs-affinity-comms.png" alt="Affinity map: Communication & Support"></div>
      <div class="cs-image-block cs-image-block--wide"><img src="/images/cs-affinity-discovery.png" alt="Affinity map: Browsing & Discovery"></div>
    </div>
  </SectionContent>

