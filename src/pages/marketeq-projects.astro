        versions: [
          { label: 'Version 1', image: '/images/cs-wireframe-overview-v1.png', imageAlt: 'Project Header v1' },
          { label: 'Version 2', image: '/images/cs-wireframe-overview-v2.png', imageAlt: 'Project Header v2' },
