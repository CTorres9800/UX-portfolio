import wfTriggersV1 from '../assets/wireframes/bm-wf-triggers-v1.svg?raw';
import wfTriggersV2 from '../assets/wireframes/bm-wf-triggers-v2.svg?raw';
import wfTriggersV3 from '../assets/wireframes/bm-wf-triggers-v3.svg?raw';
import wfAuthV1 from '../assets/wireframes/bm-wf-auth-v1.svg?raw';
