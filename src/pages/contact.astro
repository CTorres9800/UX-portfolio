---
// Contact. Deliberately not a form: every route here is one Chris already uses
// and can answer. A form would add a step and a place for mail to get lost.
const routes = [
  {
    k: 'Email',
    v: 'christophertorres17@gmail.com',
    href: 'mailto:christophertorres17@gmail.com',
    note: 'The most reliable way to reach me. I read everything.',
  },
  {
    k: 'Phone',
    v: '786.424.8475',
    href: 'tel:+17864248475',
    note: 'For when a conversation beats an email thread.',
  },
  {
    k: 'LinkedIn',
    v: 'in/christorres17',
    href: 'https://www.linkedin.com/in/christorres17/',
    note: 'Where 44 of the designers I trained left a recommendation.',
    external: true,
  },
];

// Paste a form endpoint here (Formspree, Web3Forms, Basin) to have the form post
// in-page. Until then it composes a pre-filled email instead, so it always works:
// this is a static site on GitHub Pages and there is no server to receive a POST.
const FORM_ENDPOINT = '';

const fits = [
  'Fractional or contract UX, design and product leadership',
  'Individual contributor design work, from research through to shipped product',
  'Design org build-outs, hiring, SOPs and design systems',
  'Fintech, healthcare, enterprise and B2B SaaS product work',
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow, noarchive, nosnippet, noimageindex">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="icon" href="/favicon-32.png" sizes="32x32">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <title>Contact, Christopher Torres</title>
  <meta name="description" content="Get in touch with Christopher Torres. Available for contract and fractional UX, design and product leadership.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:wght@400;700&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
  <link rel="stylesheet" href="/about.css">
  <link rel="stylesheet" href="/contact.css">
  <style>html{opacity:0}html.fonts-loaded{opacity:1;transition:opacity .15s ease-in}</style>
  <script is:inline>document.fonts.ready.then(()=>document.documentElement.classList.add('fonts-loaded'));</script>
</head>
<body>

  <div id="site-header"></div>

  <section class="hero ct-hero">
    <div class="container">
      <p class="about-eyebrow">Contact</p>
      <h1>Tell me what you&rsquo;re building and I&rsquo;ll tell you whether I&rsquo;m the <span class="highlight">right</span> person for it.</h1>
      <p class="hero-sub">Based in Atlanta, on-site, hybrid or remote. Available for contract and fractional engagements.</p>
    </div>
  </section>

  <section class="ct-form-wrap">
    <div class="container">
      <form class="ct-form" id="ct-form" novalidate>
        <div class="ct-field">
          <label for="ct-name">Your name</label>
          <input type="text" id="ct-name" name="name" autocomplete="name" required>
        </div>
        <div class="ct-field">
          <label for="ct-email">Email</label>
          <input type="email" id="ct-email" name="email" autocomplete="email" required>
        </div>
        <div class="ct-field ct-field--full">
          <label for="ct-message">What are you working on?</label>
          <textarea id="ct-message" name="message" rows="5" required></textarea>
        </div>
        <div class="ct-actions">
          <button type="submit" class="ct-submit">
            <span class="ct-submit-label">Send message</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <p class="ct-status" id="ct-status" role="status" aria-live="polite"></p>
        </div>
      </form>
    </div>
  </section>

  <section class="ct-routes">
    <div class="container">
      <ul class="ct-list">
        {routes.map((r) => (
          <li class="ct-item">
            <a href={r.href} class="ct-link" {...(r.external ? { target: '_blank', rel: 'noopener' } : {})}>
              <span class="ct-k">{r.k}</span>
              <span class="ct-v">{r.v}</span>
              <span class="ct-note">{r.note}</span>
              <span class="ct-arrow" aria-hidden="true">
                <svg width="34" height="12" viewBox="0 0 34 12" fill="none">
                  <path d="M0 6h31M26 1l5 5-5 5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="ct-call">
    <div class="container">
      <div class="ct-call-inner">
        <div class="ct-call-copy">
          <h2>Prefer a call?</h2>
          <p>Fifteen minutes is usually enough to establish whether there&rsquo;s something worth building together. No deck and no discovery process, just the problem you&rsquo;re trying to solve.</p>
        </div>
        <a href="https://tidycal.com/christopher-torres/15-minute-meeting" target="_blank" rel="noopener" class="ct-cta">
          Book 15 minutes
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M7 17L17 7M17 7H8M17 7v9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <section class="ct-fit">
    <div class="container">
      <div class="about-story-grid">
        <h2>Where I fit</h2>
        <div class="about-story-body">
          <ul class="ct-fit-list">
            {fits.map((f) => <li>{f}</li>)}
          </ul>
          <p class="ct-fit-note">If your project falls outside these but you think I could help, get in touch. Some of the best work I&rsquo;ve done started that way.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="ct-foot">
    <div class="container">
      <div class="ct-foot-inner">
        <p>Prefer to read first?</p>
        <div class="ct-foot-links">
          <a href="/about" class="underline-link">About me</a>
          <a href="/#work" class="underline-link">Case studies</a>
          <a href="/Christopher-Torres-Resume.pdf" target="_blank" rel="noopener" class="underline-link">Resume (PDF)</a>
        </div>
      </div>
    </div>
  </section>

  <div id="site-footer"></div>

  <script is:inline define:vars={{ FORM_ENDPOINT }}>
    (function () {
      var form = document.getElementById('ct-form');
      var status = document.getElementById('ct-status');
      if (!form) return;

      function say(msg, bad) {
        status.textContent = msg;
        status.classList.toggle('is-bad', !!bad);
      }

      form.addEventListener('submit', function (e) {
        e.preventDefault();
        var name = form.name.value.trim();
        var email = form.email.value.trim();
        var message = form.message.value.trim();

        if (!name || !email || !message) return say('Please fill in all three fields.', true);
        if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) return say('That email does not look right.', true);

        // No endpoint configured: compose the mail instead of pretending to send.
        if (!FORM_ENDPOINT) {
          var body = message + '\n\n' + name + '\n' + email;
          window.location.href = 'mailto:christophertorres17@gmail.com'
            + '?subject=' + encodeURIComponent('Portfolio enquiry from ' + name)
            + '&body=' + encodeURIComponent(body);
          say('Opening your email app with this filled in.');
          return;
        }

        say('Sending.');
        fetch(FORM_ENDPOINT, {
          method: 'POST',
          headers: { 'Accept': 'application/json', 'Content-Type': 'application/json' },
          body: JSON.stringify({ name: name, email: email, message: message }),
        }).then(function (r) {
          if (!r.ok) throw new Error(r.status);
          form.reset();
          say('Thank you. I will come back to you shortly.');
        }).catch(function () {
          say('That did not send. Email christophertorres17@gmail.com instead.', true);
        });
      });
    })();
  </script>
  <script is:inline src="/components.js"></script>
  <script is:inline>
    document.addEventListener('contextmenu', function(e) { e.preventDefault(); });
    document.addEventListener('keydown', function(e) {
      if (e.ctrlKey || e.metaKey) {
        var k = e.key.toLowerCase();
        if (k === 'a' || k === 'c' || k === 'u' || k === 's' || k === 'p') {
          e.preventDefault();
        }
      }
      if (e.key === 'PrintScreen') { e.preventDefault(); }
    });
    document.addEventListener('dragstart', function(e) { e.preventDefault(); });
  </script>
</body>
</html>
