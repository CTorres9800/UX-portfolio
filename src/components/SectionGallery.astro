---
interface ImageItem {
  src: string;
  alt: string;
}

interface Props {
  title: string;
  images: ImageItem[];
  columns?: 2 | 3;
  variant?: 'white' | 'gray' | 'dark';
}

const { title, images, columns = 3, variant = 'white' } = Astro.props;
const sectionClass = variant === 'gray' ? 'cs-section cs-section--gray' : variant === 'dark' ? 'cs-section cs-section--dark' : 'cs-section';
const gridClass = columns === 2 ? 'cs-image-grid cs-image-grid--2' : 'cs-image-grid cs-image-grid--3';
---

<section class={sectionClass}>
  <div class="container">
    <h2 class="cs-section-title">{title}</h2>
    <slot />
    <div class={gridClass}>
      {images.map((img) => (
        <img src={img.src} alt={img.alt}>
      ))}
    </div>
  </div>
</section>
