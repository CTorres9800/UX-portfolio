---
interface VersionGroup {
  subtitle: string;
  description?: string;
  /** Grid columns for this group. Use 2 for near full-screen wireframes,
   *  1 for artwork that is unreadable at anything less than full width. Defaults to 3. */
  columns?: 1 | 2 | 3;
  versions: {
    label: string;
    /** Path to a raster image. Ignored when `svg` is provided. */
    image?: string;
    /** Raw inline SVG markup — inlined so it inherits the page webfont. */
    svg?: string;
    imageAlt: string;
  }[];
}

interface Props {
  title: string;
  groups: VersionGroup[];
  variant?: 'white' | 'gray' | 'dark';
}

const { title, groups, variant = 'white' } = Astro.props;
const sectionClass = variant === 'gray' ? 'cs-section cs-section--gray' : variant === 'dark' ? 'cs-section cs-section--dark' : 'cs-section';
---

<section class={sectionClass}>
  <div class="container">
    <h2 class="cs-section-title">{title}</h2>
    <slot />
    {groups.map((group) => (
      <div class="cs-subsection">
        <h3 class="cs-subsection-title">{group.subtitle}</h3>
        {group.description && <p class="cs-body-text">{group.description}</p>}
        <div class={group.columns === 1 ? 'cs-versions cs-versions--1col' : group.columns === 2 ? 'cs-versions cs-versions--2col' : 'cs-versions'}>
          {group.versions.map((v) => (
            <div class="cs-version">
              <h4>{v.label}</h4>
              <div class="cs-version-card">
                {v.svg
                  ? <div class="cs-version-svg" role="img" aria-label={v.imageAlt} set:html={v.svg} />
                  : <img src={v.image} alt={v.imageAlt}>}
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
